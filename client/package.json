{
	"name": "client",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"check-format": "prettier --check .",
		"format": "prettier --check --write .",
		"lint": "eslint . --ext .tsx,ts,js,json",
		"fix-lint": "pnpm lint --fix",
		"types": "tsc --noEmit -p .",
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview"
	},
	"dependencies": {
		"@babel/core": "7.20.2",
		"@chakra-ui/react": "2.4.1",
		"@chakra-ui/styled-system": "2.3.5",
		"@emotion/react": "11.10.5",
		"@emotion/styled": "11.10.5",
		"@pkg/datagrid-chakra-ui": "workspace:*",
		"@pkg/datagrid-core": "workspace:*",
		"framer-motion": "7.6.7",
		"react": "18.2.0",
		"react-dom": "18.2.0"
	},
	"devDependencies": {
		"@types/node": "18.11.9",
		"@types/react": "18.0.25",
		"@types/react-dom": "18.0.9",
		"@utilize/eslint-config": "2.3.0",
		"@utilize/prettier-config": "1.1.0",
		"@vitejs/plugin-react": "2.2.0",
		"eslint": "8.28.0",
		"prettier": "2.7.1",
		"typescript": "4.9.3",
		"vite": "3.2.4"
	},
	"eslintConfig": {
		"extends": "@utilize/eslint-config"
	},
	"prettier": "@utilize/prettier-config"
}
